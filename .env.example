# ─── Base de données ─────────────────────────────────────
DATABASE_URL=postgresql://vita:changeme@localhost:5432/vita
POSTGRES_PASSWORD=changeme

# ─── Cache ───────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379
REDIS_PASSWORD=changeme

# ─── Authentification ────────────────────────────────────
# Générer avec : openssl rand -hex 64
# Ne pas réutiliser comme AI_SERVICE_TOKEN
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production

# ─── Communication inter-services ────────────────────────
# Token statique partagé entre data-service et ai-engine.
# Distinct du JWT_SECRET — une fuite de l'un ne compromet pas l'autre.
# Générer avec : openssl rand -hex 32
AI_SERVICE_TOKEN=your_inter_service_token_change_me
AI_ENGINE_URL=http://localhost:3003

# ─── IA ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Optionnel : Vector DB pour les patterns ────────────
PINECONE_API_KEY=
PINECONE_INDEX=vita-patterns

# ─── Services ────────────────────────────────────────────
AUTH_SERVICE_PORT=3001
DATA_SERVICE_PORT=3002
AI_ENGINE_PORT=3003

# ─── URLs autorisées (CORS) ──────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── Notifications push ──────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.vita.app
FCM_SERVER_KEY=
